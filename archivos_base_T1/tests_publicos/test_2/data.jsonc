{
    "nombre": "Test_Publico_2",
    "descripcion": "Mejor anime y mejor personaje. Test enfocado en publish/subscribe",

    // JSON con la configuración de la votación
    "configuracion": "c1",

    "eventos": [
        // Evento 1: crear subscriptor
        // Formato "crear_subscriptor", nombre_subscriptor
        ["crear_subscriptor", "Dipre"],
        ["crear_subscriptor", "PDI"],
        ["crear_subscriptor", "Fifa"],

        // Evento 2: Subscribir
        // Formato "subscribir", nombre_subscriptor, sucursal, evento
        // El subscriptor siempre debe existir. Sucursal, evento tambien o debe ser *

        ["subscribir", "Dipre", "A", "Repetido"], // Solo evento "Repetido" en A
        ["subscribir", "Dipre", "A", "Repetido"], // Filtro repetido, no pasa nada.

        ["subscribir", "PDI", "A", "*"], // Cualquier evento en A
        ["subscribir", "PDI", "*", "Cerrado"], // Evento "Cerrado" en cualquier sucursal

        ["subscribir", "Fifa", "*", "*"], // Cualquier evento en cualquier sucursal


        // ########################################################
        // Gatillaremos eventos para los subscriptores
        ["votar", "A", 1, "V1", ["Kaguya-hime!"], []],
        // Voto válido para Kaguya-hime!
        
        ["votar", "A", 1, "V1", ["Kaguya-hime!"], []],
        // EVENTO en A: "Repetido"
        // Dipre recibe notificación porque está subscrito a (A, Repetido)
        // PDI recibe notificación porque está subscrito a (A, *)
        // Fifa recibe notificación porque está subscrito a (*, *)

        ["cerrar", "A"],
        ["cerrar", "B"],

        ["votar", "A", 2, "V1", ["Kaguya-hime!"], []],
        // EVENTO en A: "Cerrado"
        // PDI recibe notificación porque está subscrito a (A, *)
        // Fifa recibe notificación porque está subscrito a (*, *)
        
        ["votar", "B", 2, "V999", ["Kaguya-hime!"], []],
        // EVENTO en B: "Cerrado" (tambien está "No existe", pero la prioridad la gana "Cerrado")
        // PDI recibe notificación porque está subscrito a (*, Cerrado)
        // Fifa recibe notificación porque está subscrito a (*, *)
        
        ["reanudar", "B"],
        ["reanudar", "A"],
        ["votar", "B", 2, "V999", ["Kaguya-hime!"], []],
        // EVENTO en B: "No existe"
        // Fifa recibe notificación porque está subscrito a (*, *)
        
        ["votar", "A", 3, "V1", ["Kaguya-hime!"], ["Indocumentado"]],
        // EVENTO en A: "Indocumentado"
        // PDI recibe notificación porque está subscrito a (A, *)
        // Fifa recibe notificación porque está subscrito a (*, *)
        
        ["votar", "C", 5, "V1", ["Kaguya-hime!"], ["Corrupto"]],
        // Notar que 5 si está asignado a C pero en "V2", no en "V1", así que para dicha
        // votación (V1) este usuario no está asignado a la sucursal C. 
        // EVENTO en C: "Sucursal incorrecta"
        // Fifa recibe notificación porque está subscrito a (*, *)

        ["votar", "A", 9, "V1", ["Kaguya-hime!"], ["Corrupto"]],
        // EVENTO en A: "Sucursal incorrecta"
        // PDI recibe notificación porque está subscrito a (A, *)
        // Fifa recibe notificación porque está subscrito a (*, *)
        // ########################################################
        
        // Evento 3: Desubscribir
        // Formato "desubscribir", nombre_subscriptor, sucursal, evento

        // Invalido porque no existe este filtro. No pasa nada.
        ["desubscribir", "Fifa", "A", "Repetido"], 

        // FIltro existe, así que se elimina y Fifa ya no tiene ningún filtro.
        ["desubscribir", "Fifa", "*", "*"],


        // ########################################################
        // Gatillaremos eventos para validar que Fifa no tenga nada
        ["votar", "A", 1, "V1", ["Kaguya-hime!"], []],
        // EVENTO en A: "Repetido"
        // Dipre recibe notificación porque está subscrito a (A, Repetido)
        // PDI recibe notificación porque está subscrito a (A, *)
        // ########################################################

        // Reportar datos y ver ganador "V1"
        ["reportar", "A"], // LOG: Sucursal A ha enviado información: 1
        ["ganador", "V1"] // LOG: Ganador {tema}: Kaguya-hime!
    ]
}